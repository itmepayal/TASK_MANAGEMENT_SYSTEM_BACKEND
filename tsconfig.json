{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "target": "ES2022",

    "outDir": "./dist",
    "rootDir": "./src",

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "types": ["node"],
    "lib": ["ES2022"],

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,

    "ignoreDeprecations": "6.0"
  }
}
